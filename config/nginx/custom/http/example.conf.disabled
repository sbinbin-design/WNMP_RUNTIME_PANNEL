# Nginx HTTP-level Custom Configuration Example
# Copy this file to config/nginx/custom/http/your-config.conf (without .disabled)
# These directives are included in the http {} block

# Example: Set maximum request body size
# client_max_body_size 100m;

# Example: Enable gzip compression
# gzip on;
# gzip_types text/plain text/css application/json application/javascript;
