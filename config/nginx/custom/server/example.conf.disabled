# Nginx Server-level Custom Configuration Example
# Copy this file to bin/nginx/conf/custom/server/your-config.conf (without .disabled)
# These directives are included in the server {} block

# Example: Add custom location block
# location /api {
#     proxy_pass http://127.0.0.1:8080;
# }

# Example: Add rewrite rule
# rewrite ^/old-path(.*)$ /new-path$1 permanent;
