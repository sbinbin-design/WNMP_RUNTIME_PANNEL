; WNMP MySQL User Custom Configuration
; This file is for advanced users to customize MySQL settings.
; Changes take effect after restarting MySQL in WNMPPanel.exe.
;
; You can directly edit config/mysql/my.ini (the active config file).
; reset-config --force will regenerate my.ini from template, which may overwrite direct edits.
; This file (my.user.ini) is an optional mechanism: its contents are appended
; when reset-config regenerates my.ini from template.

[mysqld]
; Max connections
; max_connections = 200

; InnoDB buffer pool size
; innodb_buffer_pool_size = 256M

; Connection timeout (seconds)
; wait_timeout = 28800

; Slow query log
; Replace <WNMP_ROOT> with your actual tool root directory, e.g. D:/wnmp
; slow_query_log = 1
; slow_query_log_file = <WNMP_ROOT>/logs/mysql/slow-query.log
; long_query_time = 2
