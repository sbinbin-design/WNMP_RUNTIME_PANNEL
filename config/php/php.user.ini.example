; WNMP PHP User Custom Configuration
; This file is for advanced users to customize PHP settings.
; Changes take effect after restarting PHP-CGI in WNMPPanel.exe.
;
; You can directly edit config/php/php.ini (the active config file).
; reset-config --force will regenerate php.ini from template, which may overwrite direct edits.
; This file (php.user.ini) is an optional mechanism: its contents are appended
; when reset-config regenerates php.ini from template.

; Memory limit
; memory_limit = 256M

; Upload file size limit
; upload_max_filesize = 64M

; POST data size limit
; post_max_size = 64M

; Max execution time (seconds)
; max_execution_time = 300

; Timezone
; date.timezone = Asia/Shanghai

; Custom extensions (uncomment and modify)
; extension=redis
; extension=imagick
