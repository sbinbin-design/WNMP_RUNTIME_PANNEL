/*
 * WNMPPanel.rc.template - 资源文件模板（由 sync_version.py 生成 WNMPPanel.rc）
 * 引用 UAC manifest 并设置版本信息
 * 注意：使用数值常量以兼容 llvm-rc
 *
 * 版本相关字段使用占位符，由 scripts/sync_version.py 从项目根目录 VERSION 文件读取后替换：
 *   0,2,0,0   -> FILEVERSION 数字四段，如 0,1,0,0
 *   0,2,0,0 -> PRODUCTVERSION 数字四段，如 0,1,0,0
 *   0.2.0-dev       -> 完整版本字符串，如 0.1.0-dev
 *
 * 不要直接编辑 WNMPPanel.rc，修改本模板或 VERSION 后运行 sync_version.py 即可。
 */

/* 嵌入 UAC manifest */
1 24 "WNMPPanel.manifest"

/* 应用图标 */
1 ICON "wnmp-panel.ico"

/* 版本信息 */
1 VERSIONINFO
FILEVERSION     0,2,0,0
PRODUCTVERSION  0,2,0,0
FILEFLAGSMASK   0x3F
FILEFLAGS       0
FILEOS          0x40004
FILETYPE        0x1
FILESUBTYPE     0x0
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "HTTPS://DACAT.CC"
            VALUE "FileDescription",  "WNMP Runtime Panel Launcher"
            VALUE "FileVersion",      "0.2.0-dev"
            VALUE "InternalName",     "WNMPPanel"
            VALUE "LegalCopyright",   "DACAT.CC"
            VALUE "OriginalFilename", "WNMPPanel.exe"
            VALUE "ProductName",      "WNMP Runtime"
            VALUE "ProductVersion",   "0.2.0-dev"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
